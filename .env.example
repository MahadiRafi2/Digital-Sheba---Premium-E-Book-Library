# ADMIN_PASSWORD: Required for admin panel login. Default is admin123
ADMIN_PASSWORD=admin123

# JWT_SECRET: Secret for signing auth tokens
JWT_SECRET=lumina-secret-server-key

# GOOGLE_DRIVE_FOLDER_ID: The root folder to sync from
GOOGLE_DRIVE_FOLDER_ID=

# GOOGLE_SERVICE_ACCOUNT: Stringified JSON of service account credentials
GOOGLE_SERVICE_ACCOUNT=
